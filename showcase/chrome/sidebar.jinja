{% macro sidebar(current="") -%}
{% set _base = base_path | default("") %}
{% for group_name, items in NAV %}
  <div class="ok-sidebar__group">
    <div class="ok-sidebar__section">{{ group_name }}</div>
    {% for href, label, icon, badge in items %}
      {%- set is_active = current.endswith(href.lstrip('/')) and href != '/' or (href == '/' and current.endswith('index.html')) -%}
      {%- set full_href = (_base + "/") if href == "/" else (_base + href) -%}
      <a href="{{ full_href }}"
         class="ok-sidebar__item"
         data-route-active="{{ 'true' if is_active else 'false' }}">
        <svg class="ok-sidebar__icon" width="16" height="16" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round">
          <path d="{{ icon }}"/>
        </svg>
        <span class="ok-sidebar__label">{{ label }}</span>
        {% if badge -%}<span class="ok-sidebar__badge ok-sidebar__badge--{{ badge }}">{{ badge }}</span>{%- endif %}
      </a>
    {% endfor %}
  </div>
{% endfor %}
{%- endmacro %}

{% if current is defined %}{{ sidebar(current) }}{% endif %}
