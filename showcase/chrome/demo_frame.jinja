{#def title="Demo", jinja_src="", jinjax_src="", usage="", attrs=None #}

{% macro demo_frame(title="Demo", jinja_src="", jinjax_src="", usage="", attrs=None) -%}
{%- set body = caller() -%}
{%- set _attrs = attrs or {} -%}
{# Unique id per demo block — derived from title — so multiple demo_frames per page have isolated tab signals.
   Caveat: if two demos on the same page share the same title, their tabs WILL collide. The page author
   is responsible for ensuring titles are unique on the page. #}
{# Strip ALL non-ASCII-alphanumeric chars to get a JS-safe identifier. #}
{%- set _safe = [] -%}
{%- for ch in title|lower -%}
  {%- if ch in 'abcdefghijklmnopqrstuvwxyz0123456789_' -%}
    {%- set _ = _safe.append(ch) -%}
  {%- elif ch == ' ' or ch == '-' or ch == '·' -%}
    {%- set _ = _safe.append('_') -%}
  {%- endif -%}
{%- endfor -%}
{%- set _uid = (_safe|join) or 'demo' -%}
<section class="demo-frame"
  data-signals="{ tab_{{ _uid }}: 'preview' }"
  {%- for k, v in _attrs.items() %} {{ k }}="{{ v }}"{% endfor %}>

  <header class="demo-frame__header">
    <h3 class="demo-frame__title">{{ title }}</h3>
    <div class="demo-frame__tabs" role="tablist">
      <button type="button" data-on:click="$tab_{{ _uid }} = 'preview'"
              data-attr:aria-selected="$tab_{{ _uid }} === 'preview'">Preview</button>
      <button type="button" data-on:click="$tab_{{ _uid }} = 'html'"
              data-attr:aria-selected="$tab_{{ _uid }} === 'html'">HTML</button>
      <button type="button" data-on:click="$tab_{{ _uid }} = 'jinja'"
              data-attr:aria-selected="$tab_{{ _uid }} === 'jinja'">Jinja</button>
      <button type="button" data-on:click="$tab_{{ _uid }} = 'jinjax'"
              data-attr:aria-selected="$tab_{{ _uid }} === 'jinjax'">JinjaX</button>
      <button type="button" data-on:click="$tab_{{ _uid }} = 'usage'"
              data-attr:aria-selected="$tab_{{ _uid }} === 'usage'">Usage</button>
    </div>
  </header>

  <div class="demo-frame__panel" data-show="$tab_{{ _uid }} === 'preview'">
    <div class="demo-frame__render">{{ body|safe }}</div>
  </div>

  <div class="demo-frame__panel" data-show="$tab_{{ _uid }} === 'html'" style="display:none;">
    <div class="demo-frame__code">
      <button class="demo-frame__copy" type="button"
              data-on:click="navigator.clipboard.writeText(evt.currentTarget.nextElementSibling.textContent)">Copy</button>
      <pre><code>{{ body|string|trim|e }}</code></pre>
    </div>
  </div>

  <div class="demo-frame__panel" data-show="$tab_{{ _uid }} === 'jinja'" style="display:none;">
    <div class="demo-frame__code">
      <button class="demo-frame__copy" type="button"
              data-on:click="navigator.clipboard.writeText(evt.currentTarget.nextElementSibling.textContent)">Copy</button>
      <pre><code>{{ jinja_src or "(no Jinja source provided yet)" }}</code></pre>
    </div>
  </div>

  <div class="demo-frame__panel" data-show="$tab_{{ _uid }} === 'jinjax'" style="display:none;">
    <div class="demo-frame__code">
      <button class="demo-frame__copy" type="button"
              data-on:click="navigator.clipboard.writeText(evt.currentTarget.nextElementSibling.textContent)">Copy</button>
      <pre><code>{{ jinjax_src or "(no JinjaX source provided yet)" }}</code></pre>
    </div>
  </div>

  <div class="demo-frame__panel" data-show="$tab_{{ _uid }} === 'usage'" style="display:none;">
    <div class="demo-frame__usage">
      {% if usage %}{{ usage|safe }}{% else %}
        <p>Install the Jinja addon and import the component:</p>
        <pre><code>pip install outfitkit</code></pre>
        <p>Then in your template:</p>
        <pre><code>{% raw %}{% from "ui/&lt;component&gt;.jinja" import &lt;component&gt; %}
{{ &lt;component&gt;(...) }}{% endraw %}</code></pre>
        <p>Or with JinjaX:</p>
        <pre><code>&lt;Component ... /&gt;</code></pre>
      {% endif %}
    </div>
  </div>
</section>
<style>
  .demo-frame { border: 1px solid var(--ok-line); border-radius: 12px; margin-bottom: 24px; overflow: hidden; background: var(--ok-bg-2); }
  .demo-frame__header { padding: 12px 16px 0; border-bottom: 1px solid var(--ok-line); background: var(--ok-bg-3); display: flex; align-items: flex-end; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
  .demo-frame__title { margin: 0 0 12px; font-size: 13px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--ok-ink-3); font-weight: 500; }
  .demo-frame__tabs { display: flex; gap: 2px; }
  .demo-frame__tabs button { background: transparent; border: 0; border-bottom: 2px solid transparent; padding: 8px 12px; font-size: 12px; color: var(--ok-ink-3); font-family: inherit; cursor: pointer; font-weight: 500; }
  .demo-frame__tabs button:hover { color: var(--ok-ink); }
  .demo-frame__tabs button[aria-selected="true"] { color: var(--ok-ink); border-bottom-color: var(--ok-brand); }
  .demo-frame__panel { background: var(--ok-bg-2); }
  .demo-frame__render { padding: 24px 18px; display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }
  .demo-frame__code { position: relative; background: var(--ok-bg-1); border-top: 1px solid var(--ok-line); }
  .demo-frame__code pre { margin: 0; padding: 16px 18px; padding-right: 80px; color: var(--ok-ink-2); font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 12px; line-height: 1.55; overflow-x: auto; white-space: pre; }
  .demo-frame__copy { position: absolute; top: 10px; right: 10px; padding: 4px 10px; font-size: 11px; font-weight: 500; color: var(--ok-ink-2); background: var(--ok-bg-3); border: 1px solid var(--ok-line); border-radius: 4px; cursor: pointer; font-family: inherit; }
  .demo-frame__copy:hover { color: var(--ok-ink); border-color: var(--ok-line-2); }
  .demo-frame__copy:active { transform: translateY(1px); }
  .demo-frame__usage { padding: 18px; color: var(--ok-ink-2); font-size: 13.5px; line-height: 1.6; }
  .demo-frame__usage pre { background: var(--ok-bg-1); border: 1px solid var(--ok-line); border-radius: 6px; padding: 12px; margin: 8px 0; overflow-x: auto; }
</style>
{%- endmacro %}

{% if title is defined %}
  {% call demo_frame(title, jinja_src=jinja_src, jinjax_src=jinjax_src, usage=usage, attrs=attrs) %}{{ content }}{% endcall %}
{% endif %}
