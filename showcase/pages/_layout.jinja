<!doctype html>
<html lang="es" data-theme="erplora">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{% block title %}OutfitKit{% endblock %}</title>

  {# OutfitKit CSS — desde CDN en producción, desde build/css en local. #}
  <link rel="stylesheet" href="{{ css_url }}">

  {# Datastar — reactividad declarativa via data-* sin build. #}
  <script type="module"
          src="https://cdn.jsdelivr.net/gh/starfederation/datastar@main/bundles/datastar.js"></script>

  <style>
    /* Showcase chrome — no entra en la librería ni en el paquete. */
    body {
      background: var(--ok-bg);
      color: var(--ok-ink);
      font-family: var(--ok-font, system-ui, -apple-system, sans-serif);
      margin: 0;
    }
    .showcase {
      display: grid;
      grid-template-columns: 240px 1fr;
      min-height: 100vh;
    }
    .showcase__sidebar {
      background: var(--ok-bg-2);
      border-right: 1px solid var(--ok-line);
      padding: 16px;
      overflow-y: auto;
      position: sticky;
      top: 0;
      height: 100vh;
    }
    .showcase__main {
      padding: 32px 48px;
      max-width: 1100px;
    }
    .showcase__main h1 {
      font-size: 28px;
      margin: 0 0 8px;
    }
    .showcase__lead {
      color: var(--ok-ink-3);
      margin-bottom: 32px;
    }
    @media (max-width: 768px) {
      .showcase { grid-template-columns: 1fr; }
      .showcase__sidebar {
        position: static;
        height: auto;
        border-right: 0;
        border-bottom: 1px solid var(--ok-line);
      }
      .showcase__main { padding: 24px; }
    }
  </style>
</head>
<body>
  <div class="showcase">
    <aside class="showcase__sidebar">
      <Sidebar current="{{ self._TemplateReference__context.name | default('') }}" />
    </aside>
    <main class="showcase__main">
      {% block content %}{% endblock %}
    </main>
  </div>
</body>
</html>
