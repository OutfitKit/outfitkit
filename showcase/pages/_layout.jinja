{% from "ui/avatar.jinja" import avatar %}
<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{% block title %}OutfitKit · Librería{% endblock %}</title>

  {# Inter font preload — skipped in local mode to avoid hanging on external
     resources (Playwright, offline). Google Fonts loads via @import in
     tokens.css when online; system-ui fallback covers local. #}
  {% if not local_mode %}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload"
        href="https://fonts.gstatic.com/s/inter/v13/UcC73FwrK3iLTeHuS_nVMrMxCp50SjIa1ZL7.woff2"
        as="font" type="font/woff2" crossorigin>
  {% endif %}

  {# OutfitKit CSS — desde CDN en producción, desde build/css en local. #}
  <link rel="stylesheet" href="{{ css_url }}">

  {# Theme templates — local build in local_mode, jsDelivr CDN otherwise.
     Local mode avoids Playwright hangs waiting for external CDN fetches. #}
  {% if local_mode %}
  <link rel="stylesheet" href="{{ base_path }}/css/themes/default.css">
  <link rel="stylesheet" href="{{ base_path }}/css/themes/corporate.css">
  <link rel="stylesheet" href="{{ base_path }}/css/themes/glass.css">
  <link rel="stylesheet" href="{{ base_path }}/css/themes/glass-mono.css">
  <link rel="stylesheet" href="{{ base_path }}/css/themes/mono.css">
  {% else %}
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/OutfitKit/outfitkit@main/css/themes/default.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/OutfitKit/outfitkit@main/css/themes/corporate.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/OutfitKit/outfitkit@main/css/themes/glass.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/OutfitKit/outfitkit@main/css/themes/glass-mono.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/OutfitKit/outfitkit@main/css/themes/mono.css">
  {% endif %}

  {# Showcase chrome (search highlight, viewport iframes, demo grid). #}
  <style>
    body { background: var(--bg); color: var(--ink); font-family: var(--font, system-ui, -apple-system, sans-serif); margin: 0; }

    /* Sidebar overrides for the showcase: a bit wider so labels don't truncate.
       On mobile the sidebar collapses to an off-canvas drawer (handled by
       app-shell.css), so the showcase shell must release its 250px column
       to give the doc body the full viewport width. */
    .app[data-docs] { grid-template-columns: 250px 1fr; }
    .app[data-docs] .sidebar { width: 250px; }
    @media (max-width: 767px) {
      .app[data-docs] { grid-template-columns: 1fr; }
    }

    /* Active state via [data-route-active="true"] (set by Datastar). */
    .item[data-route-active="true"] {
      background: var(--bg-3); color: var(--ink);
    }
    .item[data-route-active="true"]::before {
      content: ""; position: absolute; left: 0;
      width: 3px; height: 16px;
      background: var(--brand); border-radius: 0 2px 2px 0;
    }
    .item.is-hidden { display: none; }
    .label.is-hidden { display: none; }

    /* "Sin resultados" empty state — appears at the bottom of the nav when
       the search query matches no items. Datastar toggles display via
       data-show, we just style the rendered text. */
    .sidebar-empty {
      padding: 16px 14px;
      color: var(--ink-3);
      font-size: 12px;
      text-align: center;
      font-style: italic;
    }

    /* Section headers in the showcase sidebar nav. */
    .sidebar-section {
      padding: 16px 14px 4px;
      font-size: 10px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--ink-3);
    }

    /* Custom sidebar badges (saas / hub / new). */
    .badge saas { background: var(--info-soft); color: var(--info); }
    .badge hub { background: var(--brand-soft); color: var(--brand-3); }
    .badge new { background: var(--leaf-soft); color: var(--leaf); }

    /* Pill selector (theme + viewport) — lives in the topbar. */
    .vp { display: inline-flex; padding: 2px;
      background: var(--bg-3); border: 1px solid var(--line);
      border-radius: var(--radius-md); flex-shrink: 0; }
    .vp button { height: 26px; padding: 0 9px; font-size: 11.5px;
      color: var(--ink-3); border-radius: 5px; font-weight: 500;
      display: inline-flex; align-items: center; gap: 5px;
      background: transparent; border: 0; cursor: pointer; }
    .vp button:hover { color: var(--ink); }
    .vp button[aria-pressed="true"],
    .vp button[aria-pressed=""] {
      background: var(--bg-1); color: var(--ink);
      box-shadow: 0 1px 0 rgba(0,0,0,0.4);
    }

    /* Showcase topbar responsive — hide elements progressively so the
       viewport switcher (the most useful for previews) is the last to go. */

    /* Below ~900px the template <select> takes too much room; hide it.
       Users can still load templates via URL or localStorage. */
    @media (max-width: 899px) {
      .app[data-docs] > .page > .topbar .topbar-template { display: none; }
    }

    /* Below 600px drop the GitHub link too. */
    @media (max-width: 599px) {
      .app[data-docs] > .page > .topbar .actions {
        gap: 6px;
      }
      .app[data-docs] > .page > .topbar .actions .btn {
        display: none;
      }
      .app[data-docs] > .page > .topbar .vp button {
        padding: 0 6px;
        font-size: 11px;
      }
    }

    /* Below 420px the viewport switcher itself takes too much room; drop
       the theme switcher (light/dark) so the viewport pill fits. */
    @media (max-width: 419px) {
      .app[data-docs] > .page > .topbar [aria-label="Tema"] { display: none; }
    }

    /* Template selector — matches .vp pill aesthetic. */
    .topbar-template {
      height: 30px; padding: 0 24px 0 9px;
      background: var(--bg-3) url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='10' height='10' viewBox='0 0 24 24' fill='none' stroke='%238A8378' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><path d='m6 9 6 6 6-6'/></svg>") no-repeat right 8px center;
      border: 1px solid var(--line); border-radius: var(--radius-md);
      color: var(--ink-2); font-family: inherit; font-size: 11.5px; font-weight: 500;
      -webkit-appearance: none; appearance: none; cursor: pointer;
      flex-shrink: 0;
      max-width: 130px;
    }
    .topbar-template:hover { border-color: var(--line-2); color: var(--ink); }
    .topbar-template:focus-visible {
      outline: 0; border-color: var(--brand); box-shadow: 0 0 0 3px var(--brand-soft);
    }
    .topbar-template option { background: var(--bg-1); color: var(--ink); }

    /* Doc body — page heading + lead.
       Mobile (< 768px): full width, single 1rem of breathing room.
       Desktop  (≥ 768px): centered, 1rem block padding, ~1120px max for readability. */
    .doc__body {
      padding: 1rem;
      max-width: 100%;
    }
    @media (min-width: 768px) {
      .doc__body {
        padding: 1rem;
        max-width: 1120px;
        margin-inline: auto;
      }
    }
    .doc__title { font-family: var(--font-display, var(--font)); font-size: 28px; letter-spacing: -0.02em; margin: 0 0 8px; }
    .doc__sub { color: var(--ink-3); margin: 0 0 32px; line-height: 1.55; }

    /* "Demo grid" used by the overview page. */
    .demo-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 14px; margin-bottom: 24px; }
    .demo { background: var(--bg-2); border: 1px solid var(--line); border-radius: 12px; padding: 16px; }
    .demo__label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--ink-3); margin-bottom: 8px; font-weight: 500; }

    /* Showcase variant — small captioned wrapper used inside demo-frames
       to label individual state/size variants (sm/md/lg, on/off/disabled…). */
    .showcase-variant { display: flex; flex-direction: column; align-items: center; gap: 6px; }
    .showcase-variant__caption { font-size: var(--text-2xs); color: var(--ink-3); text-transform: lowercase; letter-spacing: 0.04em; }

    /* Demo frame chrome (per-component pages). Inherited from the original chrome/demo_frame.jinja. */
    .demo-frame { border: 1px solid var(--line); border-radius: 12px; margin-bottom: 24px; overflow: visible; background: var(--bg-2); }
    .demo-frame__render { overflow: visible; }
    .demo-frame__header { padding: 12px 18px; border-bottom: 1px solid var(--line); background: var(--bg-3); }
    .demo-frame__header h3 { margin: 0; font-size: 13px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--ink-3); font-weight: 500; }
    .demo-frame__render { padding: 24px 18px; display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }
    .demo-frame__source { margin: 0; padding: 16px 18px; background: var(--bg-1); border-top: 1px solid var(--line); color: var(--ink-2); font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 12px; line-height: 1.55; overflow-x: auto; white-space: pre; }

    /* Viewport simulator for inline content (component docs).
       Only kicks in on real DESKTOP (≥ 768px). On real mobile there is
       nothing to "simulate", we render at device size.

       The whole .doc__body becomes a "device" — a centered card with
       the simulated viewport's exact width (Tablet 768px, Mobile 375px),
       a thick rounded border, and a soft shadow so it reads as a phone
       silhouette. The body's children inherit that constrained width. */
    @media (min-width: 768px) {
      .page[data-vp="tablet"],
      .page[data-vp="mobile"] {
        background: var(--bg-1);
        padding: 24px 0;
      }
      .page[data-vp="tablet"] .doc__body,
      .page[data-vp="mobile"] .doc__body {
        margin-inline: auto;
        background: var(--bg);
        padding: 1rem;
        box-sizing: border-box;
        border: 1px solid var(--line-2);
        border-radius: 28px;
        box-shadow: 0 24px 60px rgba(0, 0, 0, 0.20);
        transition: max-width 0.28s ease, padding 0.28s ease;
      }
      .page[data-vp="tablet"] .doc__body { max-width: 768px; }
      .page[data-vp="mobile"] .doc__body { max-width: 375px; }
    }

    /* Iframe simulator (used for full-page apps in pages/apps/*).
       The iframe's actual viewport is the simulated width — so the page's
       own @media (max-width:767px) rules fire correctly inside it.

       On real desktop (≥ 768px) every app preview lives inside a centered,
       framed iframe so it visually reads as "an app in a chrome", not as
       part of the showcase shell itself. The exact width depends on the
       switcher: Desktop = ~1120px, Tablet = 820px, Mobile = 412px.

       On real mobile (< 768px) the iframe goes full-bleed and the wrap
       drops its outer padding — the app and the showcase shell merge so
       there's no wasted space on a ~390px screen. */
    .vp-frame__wrap {
      display: flex;
      justify-content: center;
      align-items: flex-start;
      padding: 0;
      background: var(--bg-1);
      min-height: calc(100vh - 56px);
      min-height: calc(100dvh - 56px);
    }
    .vp-frame {
      display: block;
      border: 0;
      width: 100%;
      height: calc(100vh - 56px);
      height: calc(100dvh - 56px);
      background: var(--bg);
      transition: max-width 0.28s ease;
    }
    @media (min-width: 768px) {
      .vp-frame__wrap {
        padding: 1rem;
        min-height: calc(100vh - 56px);
        min-height: calc(100dvh - 56px);
      }
      .vp-frame {
        height: calc(100vh - 56px - 2rem);
        height: calc(100dvh - 56px - 2rem);
        border-radius: 12px;
        box-shadow: 0 0 0 1px var(--line-2);
      }
      .page[data-vp="desktop"] .vp-frame { max-width: 1120px; }
      .page[data-vp="tablet"]  .vp-frame { max-width: 820px; }
      .page[data-vp="mobile"]  .vp-frame { max-width: 412px; }
    }

    /* Embed mode: when ?embed=1 we hide the showcase chrome and render the
       content full-bleed, so it can be loaded inside the iframe above.
       Important: we only hide chrome under .app[data-docs] — the showcase
       wrapper. Selectors must NOT match topbars/sidebars belonging to the
       embedded app's own .app shell, which is rendered inside .doc__body. */
    [data-embed="1"] .app[data-docs] > .sidebar,
    [data-embed="1"] .app[data-docs] > .backdrop,
    [data-embed="1"] .app[data-docs] > .page > .topbar { display: none !important; }
    [data-embed="1"] .app[data-docs] { grid-template-columns: 1fr; }
    [data-embed="1"] .app[data-docs] > .page > .doc__body { padding: 0; max-width: none; }
  </style>

  {# Theme runtime (synchronous, before Datastar). #}
  <script src="{{ base_path }}/static/theme-runtime.js"></script>

  {# Embed mode + iframe-based viewport simulator for full-page apps.
     Runs synchronously so the chrome never flashes before being hidden. #}
  <script>
    (function () {
      var params = new URLSearchParams(location.search);
      var isEmbed = params.get('embed') === '1';
      // Page is a "full app" if its path includes /apps/ — those need the
      // iframe sim because their own @media rules must fire on a real viewport.
      var isAppPage = location.pathname.indexOf('/apps/') !== -1;

      if (isEmbed) {
        // Inside the iframe: strip chrome (sidebar, topbar, switcher).
        document.documentElement.setAttribute('data-embed', '1');
        document.addEventListener('DOMContentLoaded', function () {
          document.body.setAttribute('data-embed', '1');
          // Make sure internal links keep the embed=1 flag — otherwise
          // navigating from one app to another inside the iframe reloads
          // the showcase chrome inside the iframe (visible duplication).
          document.addEventListener('click', function (ev) {
            var a = ev.target && ev.target.closest && ev.target.closest('a');
            if (!a || !a.href) return;
            var u;
            try { u = new URL(a.href); } catch (_) { return; }
            // Same origin only; external links untouched.
            if (u.origin !== location.origin) return;
            // Skip anchors / mailto / tel / hash-only.
            if (u.pathname === location.pathname && u.search === location.search) return;
            if (u.search.indexOf('embed=') === -1) {
              u.searchParams.set('embed', '1');
              a.href = u.toString();
            }
          }, true);
        });
      } else if (isAppPage) {
        // Outside the iframe, on an app page: replace the inline content with
        // an iframe pointing to the same URL plus ?embed=1.
        document.addEventListener('DOMContentLoaded', function () {
          var docBody = document.querySelector('.page > .doc__body');
          if (!docBody) return;
          var src = location.pathname + '?embed=1' + location.hash;
          var wrap = document.createElement('div');
          wrap.className = 'vp-frame__wrap';
          var iframe = document.createElement('iframe');
          iframe.className = 'vp-frame';
          iframe.id = 'vp-frame';
          iframe.src = src;
          iframe.title = 'App preview';
          wrap.appendChild(iframe);
          docBody.replaceWith(wrap);
        });
      }

      /* Hide the topbar back-button when we're at the showcase home —
         there's nothing to go back to and `history.back()` can either
         leave the site or do nothing. The button is rendered server-side
         so we hide it as soon as DOM is ready. */
      document.addEventListener('DOMContentLoaded', function () {
        var path = location.pathname.replace(/\/$/, '');
        var basePath = '{{ base_path }}'.replace(/\/$/, '');
        var atHome = (path === basePath || path === basePath + '/index');
        if (atHome) {
          var back = document.querySelector('.app[data-docs] > .page > .topbar .topbar-back-btn');
          if (back) back.style.display = 'none';
        }
      });
    })();
  </script>

  {# Iconify web component (lazy-loads icon sets from api.iconify.design). #}
  {% if not local_mode %}
  <script src="https://cdn.jsdelivr.net/npm/iconify-icon@2/dist/iconify-icon.min.js" defer></script>
  {% endif %}

  {# Datastar (async ESM module). #}
  {% if not local_mode %}
  <script type="module"
    src="https://cdn.jsdelivr.net/gh/starfederation/datastar@main/bundles/datastar.js"></script>
  {% endif %}
</head>
<body>
  <div class="app" data-docs
       data-signals='{"q": "", "theme": (window.okTheme && window.okTheme.getState().theme) || "erplora", "vp": "desktop", "template": (window.okTheme && window.okTheme.getState().template) || "", "sidebarOpen": false}'
       data-attr:data-sidebar="$sidebarOpen ? 'open' : ''"
       data-effect="$theme; $template; window.okTheme && window.okTheme.set($theme, $template)">

    <div class="backdrop" data-on:click="$sidebarOpen = false"></div>

    {# ====== SIDEBAR ====== #}
    <aside class="sidebar">
      <div class="head">
        <div class="sidebar-logo">OK</div>
        <div class="sidebar-brand-text">
          <span class="title md">OutfitKit</span>
          <span class="meta">v1 · Librería</span>
        </div>
      </div>

      {# Search box #}
      <div style="padding: 10px 12px 4px;">
        <div class="search">
          <span class="search__icon">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/>
            </svg>
          </span>
          <input class="input sm" type="search"
                 placeholder="Buscar componente…" data-bind:q>
        </div>
      </div>

      {# Hierarchical nav. We call the macro directly instead of using the
         JinjaX component tag, because JinjaX does not evaluate Jinja
         expressions inside component attribute strings — it would pass
         the raw "{{ ... }}" text as the current-route value, which breaks
         active-route detection. #}
      <nav class="content scroll">
        {% from "sidebar.jinja" import sidebar %}
        {{ sidebar(self._TemplateReference__context.name | default('')) }}
      </nav>

      <div class="foot">
        <div class="sidebar-user">
          <span class="avatar sm brand">OK</span>
          <div class="sidebar-user-info">
            <div class="title sm">Sistema</div>
            <div class="meta">Rama main · GH Pages</div>
          </div>
        </div>
      </div>
    </aside>

    {# ====== MAIN ====== #}
    <main class="page" data-attr:data-vp="$vp">
      <header class="topbar">
        <div class="topbar-left">
          <button class="topbar-menu-btn" aria-label="Menú lateral"
                  data-on:click="$sidebarOpen = !$sidebarOpen"
                  data-attr:aria-expanded="$sidebarOpen">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 6h18M3 12h18M3 18h18"/>
            </svg>
          </button>
          <button class="topbar-back-btn" aria-label="Volver"
                  data-on:click="history.length > 1 ? history.back() : (location.href = '{{ base_path }}/')">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M19 12H5M12 19l-7-7 7-7"/>
            </svg>
          </button>
        </div>

        <h1 class="title">{% block page_title %}{{ self.title() }}{% endblock %}</h1>

        <div class="actions">
          <div class="vp" role="tablist" aria-label="Tema">
            <button
              data-on:click="$theme = 'erplora'; window.okTheme.set('erplora', $template)"
              data-attr:aria-pressed="$theme === 'erplora'">🌙 Dark</button>
            <button
              data-on:click="$theme = 'erplora-light'; window.okTheme.set('erplora-light', $template)"
              data-attr:aria-pressed="$theme === 'erplora-light'">☀ Light</button>
          </div>
          <select class="topbar-template" aria-label="Template"
                  data-bind:template
                  data-on:change="window.okTheme.set($theme, $template); document.documentElement.setAttribute('data-template', $template)">
            <option value="">⌘ Default</option>
            <option value="default">✦ Default+</option>
            <option value="corporate">⬢ Corporate</option>
            <option value="glass">◉ Glass</option>
            <option value="glass-mono">◐ Glass-Mono</option>
            <option value="mono">○ Mono</option>
          </select>
          <div class="vp" role="tablist" aria-label="Viewport">
            <button data-on:click="$vp = 'desktop'" data-attr:aria-pressed="$vp === 'desktop'">▢ Desktop</button>
            <button data-on:click="$vp = 'tablet'"  data-attr:aria-pressed="$vp === 'tablet'">▭ Tablet</button>
            <button data-on:click="$vp = 'mobile'"  data-attr:aria-pressed="$vp === 'mobile'">▯ Mobile</button>
          </div>
          <a class="btn ghost sm"
             href="https://github.com/OutfitKit/outfitkit" target="_blank" rel="noopener">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.3.8-.6v-2c-3.2.7-3.9-1.5-3.9-1.5-.5-1.4-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.4-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.2 1.2.9-.3 1.9-.4 3-.4s2 .1 3 .4c2.2-1.5 3.2-1.2 3.2-1.2.6 1.6.2 2.8.1 3.1.7.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5z"/>
            </svg>
            GitHub
          </a>
        </div>
      </header>

      <div class="doc__body">
        {% block content %}{% endblock %}
      </div>
    </main>
  </div>
</body>
</html>
