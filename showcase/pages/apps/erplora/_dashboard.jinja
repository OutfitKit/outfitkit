{# Layout base de las páginas dashboard de ERPlora (provisional, antes de
   refactorizar cloud). Extiende el _layout del showcase y aporta:
     - sidebar + topbar fijos, con item activo parametrizable
     - inline styles para los gaps puntuales (kpi.with-icon, panel-action,
       action-list, empty.ic-circle) que aún no están en outfitkit
     - bloque `dashboard_content` para el contenido de cada página

   Variables esperadas:
     - `page_title`   → título arriba del topbar y H1 del page-header
     - `page_lead`    → subtítulo del page-header (opcional)
     - `active`       → slug del item activo en el sidebar
                         (dashboard, billing, organizaciones, usuarios,
                          configuracion, terminales, equipamiento,
                          desarrollador, perfil)
#}
{% extends "_layout.jinja" %}

{% block title %}{{ page_title|default('Dashboard') }} · ERPlora{% endblock %}
{% block page_title %}{{ page_title|default('Dashboard') }}{% endblock %}

{% block content %}
<style>
  /* Mínimo necesario para el embed (?embed=1).
     Las clases .kpi.with-icon, .ic-box, .panel-action, .action-list,
     .empty .ic-circle ahora viven en la librería outfitkit. */
  html { background: var(--bg); }
  body { margin: 0; }
  body > .erp-app { min-height: 100vh; min-height: 100dvh; }

  /* Contenedor de página con max-width como el dashboard original. */
  .erp-app .page > .content {
    max-width: 1240px;
    width: 100%;
    margin-inline: auto;
    padding: var(--space-4) var(--space-4) var(--space-5);
  }

  /* Simple data table (versión ligera de outfitkit datatable). */
  .erp-table { width: 100%; border-collapse: separate; border-spacing: 0; }
  .erp-table th, .erp-table td {
    padding: 12px 14px; text-align: left;
    border-bottom: 1px solid var(--line);
    font-size: var(--text-sm);
  }
  .erp-table th {
    font: 600 var(--text-xs)/1 var(--font-mono);
    color: var(--ink-3);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: var(--bg-3);
  }
  .erp-table tr:last-child td { border-bottom: 0; }
  .erp-table td.mono { font-family: var(--font-mono); color: var(--ink); }
  .erp-table td.muted { color: var(--ink-3); }
</style>

{% set _active = active|default('dashboard') %}

<div class="app erp-app">
  <div class="backdrop"></div>

  <!-- ═══════════════════ SIDEBAR ═══════════════════ -->
  <aside class="sidebar">
    <div class="head">
      <div class="sidebar-user">
        <span class="avatar brand avatar-md">SA</span>
        <div class="sidebar-user-info">
          <div class="title sm">Support Admin</div>
          <div class="meta">support@erplora.com</div>
        </div>
        <a class="icon-btn" href="perfil.html" aria-label="Editar perfil" style="--size: 30px;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        </a>
      </div>
    </div>

    <nav class="content scroll">
      <a class="item" href="dashboard.html" {% if _active == 'dashboard' %}data-active="true"{% endif %}>
        <span class="icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></span>
        <span class="item-label">Principal</span>
      </a>
      <a class="item" href="billing-facturas.html" {% if _active == 'billing' %}data-active="true"{% endif %}>
        <span class="icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="12" rx="2"/><line x1="2" y1="11" x2="22" y2="11"/></svg></span>
        <span class="item-label">Facturación</span>
      </a>

      <div class="sidebar-section">Gestión</div>

      <a class="item" href="organizaciones.html" {% if _active == 'organizaciones' %}data-active="true"{% endif %}>
        <span class="icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="9" y1="9" x2="9" y2="21"/><line x1="15" y1="9" x2="15" y2="21"/></svg></span>
        <span class="item-label">Organizaciones</span>
      </a>
      <a class="item" href="usuarios.html" {% if _active == 'usuarios' %}data-active="true"{% endif %}>
        <span class="icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="7" r="4"/><path d="M3 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2M16 3.13a4 4 0 0 1 0 7.75M22 21v-2a4 4 0 0 0-3-3.87"/></svg></span>
        <span class="item-label">Usuarios</span>
      </a>
      <a class="item" href="configuracion.html" {% if _active == 'configuracion' %}data-active="true"{% endif %}>
        <span class="icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09a1.65 1.65 0 0 0-1-1.51 1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09a1.65 1.65 0 0 0 1.51-1 1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33h0a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82v0a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg></span>
        <span class="item-label">Configuración</span>
      </a>

      <div class="sidebar-section">Terminales Cloud</div>

      <a class="item" href="terminales-activos.html" {% if _active == 'terminales' %}data-active="true"{% endif %}>
        <span class="icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19a4.5 4.5 0 1 0 0-9h-1.26A8 8 0 1 0 4 16.25"/></svg></span>
        <span class="item-label">Terminales</span>
      </a>

      <div class="sidebar-section">Tienda</div>

      <a class="item" href="equipamiento-tienda.html" {% if _active == 'equipamiento' %}data-active="true"{% endif %}>
        <span class="icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/></svg></span>
        <span class="item-label">Equipamiento</span>
      </a>

      <div class="sidebar-section">Desarrolladores</div>

      <a class="item" href="desarrollador-overview.html" {% if _active == 'desarrollador' %}data-active="true"{% endif %}>
        <span class="icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg></span>
        <span class="item-label">Desarrollador</span>
      </a>
    </nav>

    <div class="foot">
      <a class="item" href="#">
        <span class="icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="8" y="2" width="8" height="4" rx="1"/><path d="M5 8h14v12a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V8z"/><line x1="10" y1="14" x2="14" y2="14"/></svg></span>
        <span class="item-label">Reportar problema</span>
      </a>
      <a class="item" href="login.html">
        <span class="icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg></span>
        <span class="item-label">Cerrar sesión</span>
      </a>
    </div>
  </aside>

  <!-- ═══════════════════ MAIN ═══════════════════ -->
  <main class="page">
    <header class="topbar">
      <div class="topbar-left">
        <button class="topbar-menu-btn" aria-label="Menú">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
      </div>
      <h1 class="title">{{ page_title|default('') }}</h1>
      <div class="actions">
        {% block topbar_actions %}{% endblock %}
        <button class="icon-btn" aria-label="Notificaciones" style="--radius: var(--radius-pill); --size: 36px;">
          <iconify-icon icon="lucide:bell" width="18" height="18"></iconify-icon>
        </button>
      </div>
    </header>

    <div class="content scroll">
      {% block dashboard_content %}{% endblock %}
    </div>
    {% block dashboard_tabbar %}{% endblock %}
  </main>
</div>
{% endblock %}
