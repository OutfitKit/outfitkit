{#def label, variant="", size="md", icon=false, block=false, disabled=false, type="button", attrs=None #}

{% macro button(label, variant="", size="md", icon=false, block=false, disabled=false, type="button", attrs=None) -%}
{%- set _attrs = attrs|attr('as_dict')|default(attrs or {}) -%}
<button
  type="{{ type }}"
  class="btn {{ variant }}{% if size != 'md' %} {{ size }}{% endif %}{% if block %} block{% endif %}{% if icon %} icon{% endif %}"
  {% if disabled %}disabled aria-disabled="true"{% endif %}
  {%- for key, value in _attrs.items() %} {{ key }}="{{ value }}"{% endfor %}>{{ label }}</button>
{%- endmacro %}

{% if label is defined %}{{ button(label, variant=variant, size=size, icon=icon, block=block, disabled=disabled, type=type, attrs=attrs) }}{% endif %}
