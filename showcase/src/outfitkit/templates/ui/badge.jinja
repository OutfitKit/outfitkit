{#def label, variant=None, size="md", dot=false, attrs=None #}

{% macro badge(label, variant=None, size="md", dot=false, attrs=None) -%}
{%- set _attrs = attrs|attr('as_dict')|default(attrs or {}) -%}
<span class="{{ ok_prefix }}badge{% if variant %} {{ variant }}{% endif %}{% if size == 'sm' %} sm{% endif %}"
  {%- for key, value in _attrs.items() %} {{ key }}="{{ value }}"{% endfor %}>
  {%- if dot %}<span class="{{ ok_prefix }}badge__dot"></span>{% endif -%}
  {{ label }}
</span>
{%- endmacro %}

{% if label is defined %}{{ badge(label, variant=variant, size=size, dot=dot, attrs=attrs) }}{% endif %}
