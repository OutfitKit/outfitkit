{#def tag="div", variant="default", interactive=false, attrs=None #}

{% macro card(tag="div", variant="default", interactive=false, attrs=None) -%}
{%- set _attrs = attrs|attr('as_dict')|default(attrs or {}) -%}
<{{ tag }} class="card{% if variant != 'default' %} {{ variant }}{% endif %}{% if interactive %} interactive{% endif %}"
  {%- for key, value in _attrs.items() %} {{ key }}="{{ value }}"{% endfor %}>
  {{ caller() }}
</{{ tag }}>
{%- endmacro %}

{% if tag is defined %}
  {% call card(tag, variant=variant, interactive=interactive, attrs=attrs) %}{{ content }}{% endcall %}
{% endif %}
