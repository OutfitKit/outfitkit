{#def title=None, subtitle=None, icon=None, icon_variant="brand", align="center", padded=True, container="default", attrs=None #}

{% macro section(title=None, subtitle=None, icon=None, icon_variant="brand", align="center", padded=True, container="default", attrs=None) -%}
{%- set _attrs = attrs|attr('as_dict')|default(attrs or {}) -%}
{%- set _container_class = "" if container == "none" else (
    "container" if container == "default" else
    "container " ~ container
) -%}
<section class="section{% if padded %} padded{% endif %} {{ align }}"
  {%- for key, value in _attrs.items() %} {{ key }}="{{ value }}"{% endfor %}>
  {% if _container_class %}<div class="{{ _container_class }}">{% endif %}
    {% if icon or title or subtitle %}
    <header class="head">
      {% if icon %}
      <div class="icon-disc {{ icon_variant }}" aria-hidden="true">
        <span class="iconify" data-icon="{{ icon }}"></span>
      </div>
      {% endif %}
      {% if title %}<h2 class="title">{{ title }}</h2>{% endif %}
      {% if subtitle %}<p class="sub">{{ subtitle }}</p>{% endif %}
    </header>
    {% endif %}
    <div class="body">{{ caller() }}</div>
  {% if _container_class %}</div>{% endif %}
</section>
{%- endmacro %}

{% if title is defined or icon is defined %}
  {% call section(title=title, subtitle=subtitle, icon=icon, icon_variant=icon_variant, align=align, padded=padded, container=container, attrs=attrs) %}{{ content }}{% endcall %}
{% endif %}
