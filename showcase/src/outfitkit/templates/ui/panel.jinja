{#def title=None, sub=None, variant=None, size=None, attrs=None #}

{% macro panel(title=None, sub=None, variant=None, size=None, attrs=None) -%}
{%- set _attrs = attrs|attr('as_dict')|default(attrs or {}) -%}
<div class="panel{% if variant %} {{ variant }}{% endif %}{% if size %} {{ size }}{% endif %}"
  {%- for k, v in _attrs.items() %} {{ k }}="{{ v }}"{% endfor %}>
  {% if title or sub %}
  <header class="head">
    <div class="heading">
      {% if title %}<h3 class="title">{{ title }}</h3>{% endif %}
      {% if sub %}<p class="sub">{{ sub }}</p>{% endif %}
    </div>
  </header>
  {% endif %}
  <div class="body">{{ caller() }}</div>
</div>
{%- endmacro %}

{% if title is defined %}
  {% call panel(title=title, sub=sub, variant=variant, size=size, attrs=attrs) %}{{ content }}{% endcall %}
{% endif %}
