{#def title, desc=None, icon=None, actions=None, compact=False, attrs=None #}

{% macro empty(title, desc=None, icon=None, actions=None, compact=False, attrs=None) -%}
{%- set _attrs = attrs|attr('as_dict')|default(attrs or {}) -%}
<div class="empty{% if compact %} compact{% endif %}"
  {%- for key, v in _attrs.items() %} {{ key }}="{{ v }}"{% endfor %}>
  {%- if icon %}<div class="icon">{{ icon|safe }}</div>{% endif %}
  <h3 class="title lg">{{ title }}</h3>
  {%- if desc %}<p class="sub">{{ desc }}</p>{% endif %}
  {%- if actions %}<div class="actions">{{ actions|safe }}</div>{% endif %}
</div>
{%- endmacro %}

{% if title is defined %}{{ empty(title, desc=desc, icon=icon, actions=actions, compact=compact, attrs=attrs) }}{% endif %}
