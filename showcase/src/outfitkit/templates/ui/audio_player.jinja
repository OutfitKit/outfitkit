{#def title="", artist="", duration="00:00", current="00:00", progress=0, cover="", variant="default", playing=False, speed="×1.0", attrs=None #}

{% macro audio_player(title="", artist="", duration="00:00", current="00:00", progress=0, cover="", variant="default", playing=False, speed="×1.0", attrs=None) -%}
{%- set _attrs = attrs|attr('as_dict')|default(attrs or {}) -%}
<div class="ok-audio{% if variant != 'default' %} ok-audio--{{ variant }}{% endif %}{% if playing %} is-playing{% endif %}"
  {%- for k, v in _attrs.items() %} {{ k }}="{{ v }}"{% endfor %}>
  <button type="button" class="ok-audio__play" aria-label="Play/Pause">
    <span class="ok-audio__icon ok-audio__icon--play">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M7 5v14l12-7z"/></svg>
    </span>
    <span class="ok-audio__icon ok-audio__icon--pause">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M6 5h4v14H6zM14 5h4v14h-4z"/></svg>
    </span>
  </button>
  {%- if cover %}
  <div class="ok-audio__cover" style="background-image:url('{{ cover }}');"></div>
  {%- endif %}
  <div class="ok-audio__info">
    <div class="ok-audio__title">{{ title }}</div>
    <div class="ok-audio__artist">{{ artist }}</div>
  </div>
  <div class="ok-audio__progress">
    <span class="ok-audio__time">{{ current }}</span>
    <div class="ok-audio__bar">
      <div class="ok-audio__fill" style="width:{{ progress }}%;"><span class="ok-audio__handle"></span></div>
    </div>
    <span class="ok-audio__time">{{ duration }}</span>
  </div>
  <button type="button" class="ok-audio__vol" aria-label="Volumen">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5L6 9H2v6h4l5 4z"/><path d="M15.5 8.5a5 5 0 0 1 0 7"/></svg>
  </button>
  <button type="button" class="ok-audio__speed">{{ speed }}</button>
</div>
{%- endmacro %}

{% if title is defined %}{{ audio_player(title=title, artist=artist, duration=duration, current=current, progress=progress, cover=cover, variant=variant, playing=playing, speed=speed, attrs=attrs) }}{% endif %}
