{#def title="", artist="", duration="00:00", current="00:00", progress=0, cover="", variant="default", playing=False, speed="×1.0", attrs=None #}

{% macro audio_player(title="", artist="", duration="00:00", current="00:00", progress=0, cover="", variant="default", playing=False, speed="×1.0", attrs=None) -%}
{%- set _attrs = attrs|attr('as_dict')|default(attrs or {}) -%}
<div class="{{ ok_prefix }}audio{% if variant != 'default' %} {{ ok_prefix }}audio--{{ variant }}{% endif %}{% if playing %} is-playing{% endif %}"
  {%- for k, v in _attrs.items() %} {{ k }}="{{ v }}"{% endfor %}>
  <button type="button" class="{{ ok_prefix }}audio__play" aria-label="Play/Pause">
    <span class="{{ ok_prefix }}audio__icon {{ ok_prefix }}audio__icon--play">
      <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true"><polygon points="6 4 20 12 6 20 6 4"/></svg>
    </span>
    <span class="{{ ok_prefix }}audio__icon {{ ok_prefix }}audio__icon--pause">
      <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
    </span>
  </button>
  {%- if cover %}
  <div class="{{ ok_prefix }}audio__cover" data-playing="{{ 'true' if playing else 'false' }}" style="background-image:url('{{ cover }}');"></div>
  {%- endif %}
  <div class="{{ ok_prefix }}audio__info">
    <div class="{{ ok_prefix }}audio__title">{{ title }}</div>
    <div class="{{ ok_prefix }}audio__artist">{{ artist }}</div>
  </div>
  <div class="{{ ok_prefix }}audio__progress">
    <span class="{{ ok_prefix }}audio__time">{{ current }}</span>
    <div class="{{ ok_prefix }}audio__bar">
      <div class="{{ ok_prefix }}audio__fill" style="width:{{ progress }}%;"><span class="{{ ok_prefix }}audio__handle"></span></div>
    </div>
    <span class="{{ ok_prefix }}audio__time">{{ duration }}</span>
  </div>
  <button type="button" class="{{ ok_prefix }}audio__vol" aria-label="Volumen">
    <iconify-icon icon="lucide:volume-2" width="14" height="14"></iconify-icon>
  </button>
  <button type="button" class="{{ ok_prefix }}audio__speed">{{ speed }}</button>
</div>
{%- endmacro %}

{% if title is defined %}{{ audio_player(title=title, artist=artist, duration=duration, current=current, progress=progress, cover=cover, variant=variant, playing=playing, speed=speed, attrs=attrs) }}{% endif %}
