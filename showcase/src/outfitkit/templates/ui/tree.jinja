{#def variant="default", attrs=None #}

{% macro tree(variant="default", attrs=None) -%}
{%- set _attrs = attrs|attr('as_dict')|default(attrs or {}) -%}
<div class="tree{% if variant != 'default' %} {{ variant }}{% endif %}" role="tree"
  {%- for key, value in _attrs.items() %} {{ key }}="{{ value }}"{% endfor %}>
  {{ caller() }}
</div>
{%- endmacro %}

{#
  tree_node — branch node with reactive expand/collapse via Datastar.

  Datastar v1 signals are GLOBAL: a bare `{open: ...}` declared in nested
  `data-signals` does NOT create a scoped signal — every `$open` on the page
  points to the same variable, so toggling one node toggles all of them.

  To avoid the leak each node owns a NAMESPACED signal under a unique id,
  e.g. `data-signals="{n40: {open: true}}"` and references `$n40.open`
  everywhere. Pass `node_id` explicitly (recommended) to guarantee
  uniqueness; fallback derives one from the macro id + a module-level
  counter, which is unique within a single render but not stable across
  renders — so always pass `node_id` for production templates.

  Args:
    label    — visible row label (HTML allowed via |safe at call site)
    icon     — single character / emoji / inline SVG for the row icon
    meta     — right-aligned meta string (counts, amounts, etc.)
    expanded — initial open state (default False)
    icon_kind— "folder" or "file" (drives icon color via .ok-tree__icon--*)
    node_id  — unique signal namespace key (REQUIRED for interactive nodes
               sharing a page; if omitted, an auto id `_n<counter>` is used)
    attrs    — extra HTML attrs on the node
#}
{% macro tree_node(label="", icon="", meta="", expanded=false, icon_kind="folder", node_id=None, attrs=None) -%}
{%- set _attrs = attrs|attr('as_dict')|default(attrs or {}) -%}
{%- set _ns = node_id if node_id else '_n' ~ range(100000, 999999) | random -%}
<div class="tree__node"
     data-signals="{ {{ _ns }}: { open: {{ 'true' if expanded else 'false' }} } }"
     data-attr:data-state="${{ _ns }}.open ? 'open' : 'closed'"
     {%- for key, value in _attrs.items() %} {{ key }}="{{ value }}"{% endfor %}>
  <div class="tree__row">
    <span class="tree__caret"
          role="button"
          tabindex="0"
          data-on:click="${{ _ns }}.open = !${{ _ns }}.open"
          data-on:keydown="(evt.key === 'Enter' || evt.key === ' ') && (${{ _ns }}.open = !${{ _ns }}.open)"
          data-attr:aria-expanded="${{ _ns }}.open"
          data-attr:data-rotated="${{ _ns }}.open">▸</span>
    {%- if icon %}
    <span class="tree__icon {{ icon_kind }}">{{ icon }}</span>
    {%- endif %}
    <span class="label">{{ label|safe }}</span>
    {%- if meta %}
    <span class="meta">{{ meta }}</span>
    {%- endif %}
  </div>
  <div class="tree__children" data-show="${{ _ns }}.open" role="group">
    {{ caller() }}
  </div>
</div>
{%- endmacro %}

{#
  tree_leaf — non-expandable leaf row (file / account / endpoint).

  Args:
    label    — visible row label (HTML allowed)
    icon     — icon string
    meta     — right-aligned meta
    selected — initial selected state
    value    — opaque selection key (used by ancestor `data-signals` if any)
    attrs    — extra HTML attrs on the row
#}
{% macro tree_leaf(label="", icon="", meta="", selected=false, value=None, attrs=None) -%}
{%- set _attrs = attrs|attr('as_dict')|default(attrs or {}) -%}
<div class="tree__node">
  <div class="tree__row"
       {%- if value is not none %} data-on:click="$sel = '{{ value }}'" data-attr:aria-selected="$sel === '{{ value }}'"{%- endif %}
       {%- if selected %} aria-selected="true"{%- endif %}
       {%- for key, value in _attrs.items() %} {{ key }}="{{ value }}"{% endfor %}>
    <span class="tree__caret leaf"></span>
    {%- if icon %}
    <span class="tree__icon file">{{ icon }}</span>
    {%- endif %}
    <span class="label">{{ label|safe }}</span>
    {%- if meta %}
    <span class="meta">{{ meta }}</span>
    {%- endif %}
  </div>
</div>
{%- endmacro %}

{% if variant is defined %}
  {% call tree(variant=variant, attrs=attrs) %}{{ content }}{% endcall %}
{% endif %}
