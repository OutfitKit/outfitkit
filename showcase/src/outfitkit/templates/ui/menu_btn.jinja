{#def label="Menú", expanded=False, mobile_only=False, attrs=None #}

{% macro menu_btn(label="Menú", expanded=False, mobile_only=False, attrs=None) -%}
{%- set _attrs = attrs|attr('as_dict')|default(attrs or {}) -%}
<button class="menu-btn{% if mobile_only %} mobile-only{% endif %}"
  aria-label="{{ label }}"
  aria-expanded="{{ 'true' if expanded else 'false' }}"
  {%- for key, value in _attrs.items() %} {{ key }}="{{ value }}"{% endfor %}>
  <span class="menu-btn-lines"><span class="menu-btn-line"></span><span class="menu-btn-line"></span><span class="menu-btn-line"></span></span>
</button>
{%- endmacro %}

{% if label is defined %}{{ menu_btn(label=label, expanded=expanded, mobile_only=mobile_only, attrs=attrs) }}{% endif %}
