{#def label, src=None, alt="", size="md", variant=None, attrs=None #}

{% macro avatar(label, src=None, alt="", size="md", variant=None, attrs=None) -%}
{%- set _attrs = attrs|attr('as_dict')|default(attrs or {}) -%}
<span class="{{ ok_prefix }}avatar{% if size != 'md' %} {{ ok_prefix }}avatar--{{ size }}{% endif %}{% if variant %} {{ ok_prefix }}avatar--{{ variant }}{% endif %}"
  {%- for key, value in _attrs.items() %} {{ key }}="{{ value }}"{% endfor %}>
  <span class="{{ ok_prefix }}avatar__initials">{{ label }}</span>
  {%- if src %}<img src="{{ src }}" alt="{{ alt }}" onerror="this.remove()"/>{% endif -%}
</span>
{%- endmacro %}

{% if label is defined %}{{ avatar(label, src=src, alt=alt, size=size, variant=variant, attrs=attrs) }}{% endif %}
