{#def label, name="", value="", checked=false, disabled=false, attrs=None #}

{% macro checkbox(label, name="", value="", checked=false, disabled=false, attrs=None) -%}
{%- set _attrs = attrs|attr('as_dict')|default(attrs or {}) -%}
<label class="ok-check">
  <input type="checkbox"
    {% if name %}name="{{ name }}"{% endif %}
    {% if value %}value="{{ value }}"{% endif %}
    {% if checked %}checked{% endif %}
    {% if disabled %}disabled{% endif %}
    {%- for k, v in _attrs.items() %} {{ k }}="{{ v }}"{% endfor %}>
  <span class="ok-check__box"></span>
  {{ label }}
</label>
{%- endmacro %}

{% if label is defined %}{{ checkbox(label, name=name, value=value, checked=checked, disabled=disabled, attrs=attrs) }}{% endif %}
