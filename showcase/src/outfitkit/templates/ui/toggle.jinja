{#def name, checked=false, disabled=false, size="md", attrs=None #}

{% macro toggle(name, checked=false, disabled=false, size="md", attrs=None) -%}
{%- set _attrs = attrs|attr('as_dict')|default(attrs or {}) -%}
<label class="toggle{% if size != 'md' %} {{ size }}{% endif %}">
  <input type="checkbox"
    name="{{ name }}"
    {% if checked %}checked{% endif %}
    {% if disabled %}disabled{% endif %}
    {%- for k, v in _attrs.items() %} {{ k }}="{{ v }}"{% endfor %}>
  <span class="toggle-track"></span>
</label>
{%- endmacro %}

{% if name is defined %}{{ toggle(name, checked=checked, disabled=disabled, size=size, attrs=attrs) }}{% endif %}
