{#def title="", range=False, attrs=None #}

{% macro datepicker(title="", range=False, attrs=None) -%}
{%- set _attrs = attrs|attr('as_dict')|default(attrs or {}) -%}
<div class="ok-datepicker{% if range %} ok-datepicker--range{% endif %}"
  {%- for k, v in _attrs.items() %} {{ k }}="{{ v }}"{% endfor %}>
  {%- if title %}
  <div class="ok-datepicker__head">
    <span class="ok-datepicker__title">{{ title }}</span>
    <span class="ok-datepicker__nav">
      <button type="button" class="ok-datepicker__nav-btn" aria-label="Anterior"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"/></svg></button>
      <button type="button" class="ok-datepicker__nav-btn" aria-label="Siguiente"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg></button>
    </span>
  </div>
  {%- endif %}
  {{ caller() }}
</div>
{%- endmacro %}

{% if title is defined %}
  {% call datepicker(title=title, range=range, attrs=attrs) %}{{ content }}{% endcall %}
{% endif %}
