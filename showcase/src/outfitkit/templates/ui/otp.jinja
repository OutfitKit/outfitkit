{#def length=6, value="", size="md", mode="numeric", separator_at=None, attrs=None #}

{% macro otp(length=6, value="", size="md", mode="numeric", separator_at=None, attrs=None) -%}
{%- set _attrs = attrs|attr('as_dict')|default(attrs or {}) -%}
{%- set _is_alpha = (mode == 'alphanumeric') -%}
<div class="otp{% if size == 'sm' %} sm{% elif size == 'lg' %} lg{% endif %}"
  {%- for k, v in _attrs.items() %} {{ k }}="{{ v }}"{% endfor %}>
  {%- for i in range(length) %}
    {%- if separator_at is not none and i == separator_at %}
    <span class="divider">—</span>
    {%- endif %}
    <input type="text" class="otp__cell" maxlength="1"
      {% if value and i < value|length %}value="{{ value[i] }}"{% endif %}
      {% if _is_alpha %}inputmode="text" pattern="[A-Za-z0-9]"{% else %}inputmode="numeric" pattern="[0-9]"{% endif %}
      autocomplete="one-time-code"/>
  {%- endfor %}
</div>
{%- endmacro %}

{% if length is defined %}{{ otp(length=length, value=value, size=size, mode=mode, separator_at=separator_at, attrs=attrs) }}{% endif %}
