{#def title="", subtitle="", icon=None, icon_kind="brand", icon_size="md", href=None, variant=None, attrs=None #}

{# icon_kind: 'brand' (default) | 'success' | 'warn' | 'danger' | 'info' | 'neutral' | 'solid' | 'outline'
   icon_size: 'sm' | 'md' (default) | 'lg' | 'xl'
   variant:   None (default) | 'compact' | 'horizontal' | 'elevated' | 'flat' | 'glass'
   icon:      string (iconify name) o None — si None, intenta caller() para SVG custom
#}

{% macro feature_card(title="", subtitle="", icon=None, icon_kind="brand", icon_size="md", href=None, variant=None, attrs=None) -%}
{%- set _attrs = attrs|attr('as_dict')|default(attrs or {}) -%}
{%- set _tag = "a" if href else "article" -%}
{%- set _interactive = " interactive" if href else "" -%}
{%- set _variant = " " ~ variant if variant else "" -%}
{%- set _icon_kind = "" if icon_kind == "brand" else " " ~ icon_kind -%}
{%- set _icon_size = "" if icon_size == "md" else " " ~ icon_size -%}
<{{ _tag }} class="feature-card{{ _variant }}{{ _interactive }}"
  {%- if href %} href="{{ href }}"{% endif %}
  {%- for key, value in _attrs.items() %} {{ key }}="{{ value }}"{% endfor %}>
  {% if icon or caller is defined %}
  <span class="icon-box{{ _icon_kind }}{{ _icon_size }}" aria-hidden="true">
    {%- if icon %}<iconify-icon icon="{{ icon }}"></iconify-icon>
    {%- elif caller is defined %}{{ caller() }}
    {%- endif %}
  </span>
  {% endif %}
  {% if variant == "horizontal" %}
  <div class="content">
    {% if title %}<h3>{{ title }}</h3>{% endif %}
    {% if subtitle %}<p>{{ subtitle }}</p>{% endif %}
  </div>
  {% else %}
  {% if title %}<h3>{{ title }}</h3>{% endif %}
  {% if subtitle %}<p>{{ subtitle }}</p>{% endif %}
  {% endif %}
</{{ _tag }}>
{%- endmacro %}

{% if title is defined %}{{ feature_card(title=title, subtitle=subtitle, icon=icon, icon_kind=icon_kind, icon_size=icon_size, href=href, variant=variant, attrs=attrs) }}{% endif %}
