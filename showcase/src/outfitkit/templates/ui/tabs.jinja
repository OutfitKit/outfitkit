{#def variant="default", attrs=None #}

{% macro tabs(variant="default", attrs=None) -%}
{%- set _attrs = attrs|attr('as_dict')|default(attrs or {}) -%}
<div class="{{ ok_prefix }}tabs{% if variant != 'default' %} {{ ok_prefix }}tabs--{{ variant }}{% endif %}" role="tablist"
  {%- for key, value in _attrs.items() %} {{ key }}="{{ value }}"{% endfor %}>
  {{ caller() }}
</div>
{%- endmacro %}

{% if variant is defined %}
  {% call tabs(variant=variant, attrs=attrs) %}{{ content }}{% endcall %}
{% endif %}
