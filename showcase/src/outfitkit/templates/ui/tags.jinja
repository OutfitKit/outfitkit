{#def attrs=None #}

{% macro tags(attrs=None) -%}
{%- set _attrs = attrs|attr('as_dict')|default(attrs or {}) -%}
<div class="{{ ok_prefix }}tags"
  {%- for k, v in _attrs.items() %} {{ k }}="{{ v }}"{% endfor %}>
  {{ caller() }}
</div>
{%- endmacro %}

{% macro tag(label, variant=None, size=None, solid=False, removable=False, remove_action="", attrs=None) -%}
{%- set _tattrs = attrs|attr('as_dict')|default(attrs or {}) -%}
<span class="{{ ok_prefix }}tag
  {%- if solid %} solid{% endif %}
  {%- if variant %} {{ variant }}{% endif %}
  {%- if size %} {{ size }}{% endif %}
  {%- if removable %} is-removable{% endif %}"
  {%- for k, v in _tattrs.items() %} {{ k }}="{{ v }}"{% endfor %}>
  {{ label }}
  {%- if removable %}
  <button type="button" class="{{ ok_prefix }}tag__remove"
    {% if remove_action %}data-on:click="{{ remove_action }}"{% endif %}
    aria-label="Eliminar">×</button>
  {%- endif %}
</span>
{%- endmacro %}

{% if attrs is defined %}
  {% call tags(attrs=attrs) %}{{ content }}{% endcall %}
{% endif %}
