{#def placeholder="Buscar…", name="q", value="", clearable=True, kbd="", size=None, attrs=None #}

{% macro search(placeholder="Buscar…", name="q", value="", clearable=True, kbd="", size=None, attrs=None) -%}
{%- set _attrs = attrs|attr('as_dict')|default(attrs or {}) -%}
<div class="{{ ok_prefix }}search"
  {%- for k, v in _attrs.items() %} {{ k }}="{{ v }}"{% endfor %}>
  <span class="{{ ok_prefix }}search__icon">
    <iconify-icon icon="lucide:search" width="16" height="16"></iconify-icon>
  </span>
  <input type="search"
    class="{{ ok_prefix }}input{% if size == 'sm' %} sm{% elif size == 'lg' %} lg{% endif %}"
    name="{{ name }}"
    placeholder="{{ placeholder }}"
    value="{{ value }}"/>
  {%- if kbd %}
  <kbd class="{{ ok_prefix }}search__kbd">{{ kbd }}</kbd>
  {%- elif clearable %}
  <button type="button" class="{{ ok_prefix }}search__clear" aria-label="Limpiar">×</button>
  {%- endif %}
</div>
{%- endmacro %}

{% if placeholder is defined %}{{ search(placeholder=placeholder, name=name, value=value, clearable=clearable, kbd=kbd, size=size, attrs=attrs) }}{% endif %}
