{#def variant="default", attrs=None #}

{% macro chart(variant="default", attrs=None) -%}
{%- set _attrs = attrs|attr('as_dict')|default(attrs or {}) -%}
<div class="chart{% if variant != 'default' %} {{ variant }}{% endif %}"
  {%- for key, value in _attrs.items() %} {{ key }}="{{ value }}"{% endfor %}>
  {{ caller() }}
</div>
{%- endmacro %}

{% if variant is defined %}
  {% call chart(variant=variant, attrs=attrs) %}{{ content }}{% endcall %}
{% endif %}
