{#def value=0, label=None, value_text=None, variant=None, size="md", indeterminate=False, striped=False, attrs=None #}

{% macro progress(value=0, label=None, value_text=None, variant=None, size="md", indeterminate=False, striped=False, attrs=None) -%}
{%- set _attrs = attrs|attr('as_dict')|default(attrs or {}) -%}
{%- if label is not none -%}
<div class="{{ ok_prefix }}progress-block">
  <div class="{{ ok_prefix }}progress-block__head">
    <span class="{{ ok_prefix }}progress-block__label">{{ label }}</span>
    {%- if value_text is not none %}<span class="{{ ok_prefix }}progress-block__value">{{ value_text }}</span>{% endif %}
  </div>
  <div class="{{ ok_prefix }}progress{% if variant %} {{ ok_prefix }}progress--{{ variant }}{% endif %}{% if size != 'md' %} {{ ok_prefix }}progress--{{ size }}{% endif %}{% if indeterminate %} {{ ok_prefix }}progress--indeterminate{% endif %}{% if striped %} {{ ok_prefix }}progress--striped{% endif %}"
    role="progressbar"
    aria-label="{{ label }}"
    aria-valuemin="0" aria-valuemax="100"{% if not indeterminate %} aria-valuenow="{{ value }}"{% endif %}
    {%- for key, v in _attrs.items() %} {{ key }}="{{ v }}"{% endfor %}>
    <div class="{{ ok_prefix }}progress__bar"{% if not indeterminate %} style="width: {{ value }}%;"{% endif %}></div>
  </div>
</div>
{%- else -%}
<div class="{{ ok_prefix }}progress{% if variant %} {{ ok_prefix }}progress--{{ variant }}{% endif %}{% if size != 'md' %} {{ ok_prefix }}progress--{{ size }}{% endif %}{% if indeterminate %} {{ ok_prefix }}progress--indeterminate{% endif %}{% if striped %} {{ ok_prefix }}progress--striped{% endif %}"
  role="progressbar"
  aria-valuemin="0" aria-valuemax="100"{% if not indeterminate %} aria-valuenow="{{ value }}"{% endif %}
  {%- for key, v in _attrs.items() %} {{ key }}="{{ v }}"{% endfor %}>
  <div class="{{ ok_prefix }}progress__bar"{% if not indeterminate %} style="width: {{ value }}%;"{% endif %}></div>
</div>
{%- endif %}
{%- endmacro %}

{% if value is defined %}{{ progress(value=value, label=label, value_text=value_text, variant=variant, size=size, indeterminate=indeterminate, striped=striped, attrs=attrs) }}{% endif %}
