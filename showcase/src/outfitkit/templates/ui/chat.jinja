{#def attrs=None #}

{% macro chat(attrs=None) -%}
{%- set _attrs = attrs|attr('as_dict')|default(attrs or {}) -%}
<div class="chat"
  {%- for key, value in _attrs.items() %} {{ key }}="{{ value }}"{% endfor %}>
  {{ caller() }}
</div>
{%- endmacro %}

{% macro chat_composer(placeholder="Escribe un mensaje…") -%}
<div class="chat__composer">
  <textarea class="chat__composer-input" rows="1" placeholder="{{ placeholder }}"></textarea>
  <button class="chat__composer-send" aria-label="Enviar mensaje" type="button">
    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="22" y1="2" x2="11" y2="13"/>
      <polygon points="22 2 15 22 11 13 2 9 22 2"/>
    </svg>
  </button>
</div>
{%- endmacro %}

{% if attrs is defined %}
  {% call chat(attrs=attrs) %}{{ content }}{% endcall %}
{% endif %}
