{#def attrs=None #}

{% macro sidebar_nav(attrs=None) -%}
{%- set _attrs = attrs|attr('as_dict')|default(attrs or {}) -%}
<aside class="sidebar"
  {%- for k, v in _attrs.items() %} {{ k }}="{{ v }}"{% endfor %}>
  {{ caller() }}
</aside>
{%- endmacro %}

{% if attrs is defined %}
  {% call sidebar_nav(attrs=attrs) %}{{ content }}{% endcall %}
{% endif %}
