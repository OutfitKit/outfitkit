{#def title, subtitle="", side="right", state="closed", attrs=None #}

{% macro drawer(title, subtitle="", side="right", state="closed", attrs=None) -%}
{%- set _attrs = attrs|attr('as_dict')|default(attrs or {}) -%}
<div class="drawer-root" data-state="{{ state }}"
  {%- for key, value in _attrs.items() %} {{ key }}="{{ value }}"{% endfor %}>
  <div class="backdrop"></div>
  <aside class="drawer{% if side != 'right' %} {{ side }}{% endif %}">
    <div class="drawer__header">
      <h3 class="drawer__title">{{ title }}</h3>
      {% if subtitle %}<p class="drawer__sub">{{ subtitle }}</p>{% endif %}
      <button class="drawer__close" aria-label="Cerrar">✕</button>
    </div>
    <div class="drawer__body">{{ caller() }}</div>
  </aside>
</div>
{%- endmacro %}

{% if title is defined %}
  {% call drawer(title, subtitle=subtitle, side=side, state=state, attrs=attrs) %}{{ content }}{% endcall %}
{% endif %}
