{#def value=0, max=5, size="md", readonly=False, label="", attrs=None #}

{% macro rating(value=0, max=5, size="md", readonly=False, label="", attrs=None) -%}
{%- set _attrs = attrs|attr('as_dict')|default(attrs or {}) -%}
<div class="ok-rating{% if size == 'sm' %} ok-rating--sm{% elif size == 'lg' %} ok-rating--lg{% endif %}{% if readonly %} ok-rating--readonly{% endif %}"
  {%- for k, v in _attrs.items() %} {{ k }}="{{ v }}"{% endfor %}>
  {%- for i in range(1, max + 1) %}
  <iconify-icon class="ok-rating__star{% if i <= value %} ok-rating__star--filled{% endif %}"
    icon="lucide:star{% if i <= value %}{% endif %}" width="16" height="16"></iconify-icon>
  {%- endfor %}
  {%- if label %}<span class="ok-rating__label">{{ label }}</span>{% endif %}
</div>
{%- endmacro %}

{% if value is defined %}{{ rating(value=value, max=max, size=size, readonly=readonly, label=label, attrs=attrs) }}{% endif %}
