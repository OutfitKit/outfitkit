{#def variant=None, attrs=None #}

{% macro stats(variant=None, attrs=None) -%}
{%- set _attrs = attrs|attr('as_dict')|default(attrs or {}) -%}
<div class="ok-stats{% if variant %} ok-stats--{{ variant }}{% endif %}"
  {%- for k, v in _attrs.items() %} {{ k }}="{{ v }}"{% endfor %}>
  {{ caller() }}
</div>
{%- endmacro %}

{% if variant is defined %}
  {% call stats(variant=variant, attrs=attrs) %}{{ content }}{% endcall %}
{% endif %}
