{#def title, description="", variant="info", dismissible=false, attrs=None #}

{% macro banner(title, description="", variant="info", dismissible=false, attrs=None) -%}
{%- set _attrs = attrs|attr('as_dict')|default(attrs or {}) -%}
<div class="ok-banner ok-banner--{{ variant }}"
  {%- for key, value in _attrs.items() %} {{ key }}="{{ value }}"{% endfor %}>
  <span class="ok-banner__icon">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
  </span>
  <div class="ok-banner__body">
    <div class="ok-banner__title">{{ title }}</div>
    {% if description %}<div class="ok-banner__desc">{{ description }}</div>{% endif %}
  </div>
  {{ caller() }}
  {% if dismissible %}<button class="ok-banner__close" aria-label="Cerrar">×</button>{% endif %}
</div>
{%- endmacro %}

{% if title is defined %}
  {% call banner(title, description=description, variant=variant, dismissible=dismissible, attrs=attrs) %}{{ content }}{% endcall %}
{% endif %}
