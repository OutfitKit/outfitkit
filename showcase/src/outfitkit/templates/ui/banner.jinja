{#def title, description="", variant="info", dismissible=false, icon=None, attrs=None #}

{% macro banner(title, description="", variant="info", dismissible=false, icon=None, attrs=None) -%}
{%- set _attrs = attrs|attr('as_dict')|default(attrs or {}) -%}
<div class="{{ ok_prefix }}banner {{ variant }}"
  {%- for key, value in _attrs.items() %} {{ key }}="{{ value }}"{% endfor %}>
  <span class="{{ ok_prefix }}banner__icon" aria-hidden="true">
    {%- if icon -%}
    {{ icon|safe }}
    {%- elif variant == "ok" or variant == "success" -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><circle cx="12" cy="12" r="10"/><polyline points="9 12 12 15 17 10"/></svg>
    {%- elif variant == "warn" -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
    {%- elif variant == "danger" -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
    {%- elif variant == "brand" -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="M12 2 15 8l6 1-4.5 4.4L18 20l-6-3-6 3 1.5-6.6L3 9l6-1Z"/></svg>
    {%- else -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
    {%- endif -%}
  </span>
  <div class="{{ ok_prefix }}banner__body">
    <div class="{{ ok_prefix }}banner__title">{{ title }}</div>
    {% if description %}<div class="{{ ok_prefix }}banner__desc">{{ description }}</div>{% endif %}
  </div>
  {{ caller() }}
  {% if dismissible %}<button class="{{ ok_prefix }}banner__close" aria-label="Cerrar">×</button>{% endif %}
</div>
{%- endmacro %}

{% if title is defined %}
  {% call banner(title, description=description, variant=variant, dismissible=dismissible, icon=icon, attrs=attrs) %}{{ content }}{% endcall %}
{% endif %}
</content>
</invoke>