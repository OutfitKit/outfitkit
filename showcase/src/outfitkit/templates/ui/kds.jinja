{#def variant=None, attrs=None #}

{% macro kds(variant=None, attrs=None) -%}
{%- set _attrs = attrs|attr('as_dict')|default(attrs or {}) -%}
<article class="{{ ok_prefix }}kds{% if variant %} {{ ok_prefix }}kds--{{ variant }}{% endif %}"
  {%- for key, value in _attrs.items() %} {{ key }}="{{ value }}"{% endfor %}>
  {{ caller() }}
</article>
{%- endmacro %}

{% if variant is defined %}
  {% call kds(variant=variant, attrs=attrs) %}{{ content }}{% endcall %}
{% endif %}
