{#def hours=None, minutes=None, hour=None, minute=None, attrs=None #}

{% macro timepicker(hours=None, minutes=None, hour=None, minute=None, attrs=None) -%}
{%- set _attrs = attrs|attr('as_dict')|default(attrs or {}) -%}
{%- set _hours = hours or range(7, 15) | list -%}
{%- set _minutes = minutes or [0, 15, 30, 45] -%}
<div class="timepicker"
  {%- for k, v in _attrs.items() %} {{ k }}="{{ v }}"{% endfor %}>
  <div class="timepicker-col">
    {%- for h in _hours %}
    <button type="button" class="timepicker-opt"
      {% if hour == h %}aria-selected="true"{% endif %}>{{ "%02d"|format(h) }}</button>
    {%- endfor %}
  </div>
  <div class="timepicker-col">
    {%- for m in _minutes %}
    <button type="button" class="timepicker-opt"
      {% if minute == m %}aria-selected="true"{% endif %}>{{ "%02d"|format(m) }}</button>
    {%- endfor %}
  </div>
</div>
{%- endmacro %}

{% if hours is defined %}{{ timepicker(hours=hours, minutes=minutes, hour=hour, minute=minute, attrs=attrs) }}{% endif %}
