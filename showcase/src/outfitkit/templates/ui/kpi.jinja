{#def label, value, unit=None, delta=None, delta_dir=None, variant=None, sparkline=None, attrs=None #}

{% macro kpi(label, value, unit=None, delta=None, delta_dir=None, variant=None, sparkline=None, attrs=None) -%}
{%- set _attrs = attrs|attr('as_dict')|default(attrs or {}) -%}
<div class="kpi{% if variant %} {{ variant }}{% endif %}"
  {%- for key, value_attr in _attrs.items() %} {{ key }}="{{ value_attr }}"{% endfor %}>
  <div class="label">{{ label }}</div>
  <div class="value">{{ value }}{% if unit %}<span class="unit">{{ unit }}</span>{% endif %}</div>
  {%- if delta %}
  <div class="kpi__delta{% if delta_dir %} {{ delta_dir }}{% endif %}">
    {%- if delta_dir == 'up' -%}
      <iconify-icon class="kpi__delta-arrow" icon="lucide:arrow-up-right" width="14" height="14"></iconify-icon>
    {%- elif delta_dir == 'down' -%}
      <iconify-icon class="kpi__delta-arrow" icon="lucide:arrow-down-right" width="14" height="14"></iconify-icon>
    {%- endif %}
    {{ delta }}
  </div>
  {%- endif %}
  {%- if sparkline %}{{ sparkline|safe }}{% endif %}
</div>
{%- endmacro %}

{% if label is defined %}{{ kpi(label, value, unit=unit, delta=delta, delta_dir=delta_dir, variant=variant, sparkline=sparkline, attrs=attrs) }}{% endif %}
