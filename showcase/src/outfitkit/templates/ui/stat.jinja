{#def label, value, delta=None, delta_dir=None, attrs=None #}

{% macro stat(label, value, delta=None, delta_dir=None, attrs=None) -%}
{%- set _attrs = attrs|attr('as_dict')|default(attrs or {}) -%}
<div class="stat"
  {%- for key, v in _attrs.items() %} {{ key }}="{{ v }}"{% endfor %}>
  <div class="label">{{ label }}</div>
  <div class="value">{{ value }}</div>
  {%- if delta %}<div class="delta{% if delta_dir %} {{ delta_dir }}{% endif %}">{{ delta }}</div>{% endif %}
</div>
{%- endmacro %}

{% if label is defined %}{{ stat(label, value, delta=delta, delta_dir=delta_dir, attrs=attrs) }}{% endif %}
