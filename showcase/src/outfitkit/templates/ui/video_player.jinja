{#def poster="", src="", duration="00:00", current="00:00", progress=0, playing=False, attrs=None #}

{% macro video_player(poster="", src="", duration="00:00", current="00:00", progress=0, playing=False, attrs=None) -%}
{%- set _attrs = attrs|attr('as_dict')|default(attrs or {}) -%}
<div class="video{% if playing %} is-playing{% endif %}" data-playing="{{ 'true' if playing else 'false' }}"
  {%- for k, v in _attrs.items() %} {{ k }}="{{ v }}"{% endfor %}>
  {%- if poster %}
  <div class="poster" style="background-image:url('{{ poster }}');"></div>
  {%- endif %}
  {%- if src %}
  <video class="el" src="{{ src }}" preload="metadata"></video>
  {%- endif %}
  <button type="button" class="overlay" aria-label="Reproducir"></button>
  <div class="controls">
    <button type="button" class="btn" aria-label="{% if playing %}Pausar{% else %}Reproducir{% endif %}" title="{% if playing %}Pausar{% else %}Reproducir{% endif %}">
      <iconify-icon class="play" icon="lucide:play" width="14" height="14"></iconify-icon>
      <iconify-icon class="pause" icon="lucide:pause" width="14" height="14"></iconify-icon>
    </button>
    <span class="time">{{ current }}</span>
    <div class="progress">
      <div class="fill" style="width:{{ progress }}%;"></div>
    </div>
    <span class="time">{{ duration }}</span>
    <button type="button" class="volume" aria-label="Volumen">
      <iconify-icon icon="lucide:volume-2" width="14" height="14"></iconify-icon>
    </button>
    <button type="button" class="fullscreen" aria-label="Pantalla completa">
      <iconify-icon icon="lucide:maximize" width="14" height="14"></iconify-icon>
    </button>
  </div>
</div>
{%- endmacro %}

{% if poster is defined %}{{ video_player(poster=poster, src=src, duration=duration, current=current, progress=progress, playing=playing, attrs=attrs) }}{% endif %}
