{#def poster="", src="", duration="00:00", current="00:00", progress=0, playing=False, attrs=None #}

{% macro video_player(poster="", src="", duration="00:00", current="00:00", progress=0, playing=False, attrs=None) -%}
{%- set _attrs = attrs|attr('as_dict')|default(attrs or {}) -%}
<div class="ok-video{% if playing %} is-playing{% endif %}"
  {%- for k, v in _attrs.items() %} {{ k }}="{{ v }}"{% endfor %}>
  {%- if poster %}
  <div class="ok-video__poster" style="background-image:url('{{ poster }}');"></div>
  {%- endif %}
  {%- if src %}
  <video class="ok-video__el" src="{{ src }}" preload="metadata"></video>
  {%- endif %}
  <button type="button" class="ok-video__play-overlay" aria-label="Reproducir"></button>
  <div class="ok-video__controls">
    <button type="button" class="ok-video__btn" aria-label="Play/Pause">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M7 5v14l12-7z"/></svg>
    </button>
    <span class="ok-video__time">{{ current }}</span>
    <div class="ok-video__progress">
      <div class="ok-video__progress-fill" style="width:{{ progress }}%;"></div>
    </div>
    <span class="ok-video__time">{{ duration }}</span>
    <button type="button" class="ok-video__volume" aria-label="Volumen">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5L6 9H2v6h4l5 4z"/><path d="M15.5 8.5a5 5 0 0 1 0 7"/></svg>
    </button>
    <button type="button" class="ok-video__fullscreen" aria-label="Pantalla completa">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9V5a2 2 0 0 1 2-2h4M21 9V5a2 2 0 0 0-2-2h-4M3 15v4a2 2 0 0 0 2 2h4M21 15v4a2 2 0 0 1-2 2h-4"/></svg>
    </button>
  </div>
</div>
{%- endmacro %}

{% if poster is defined %}{{ video_player(poster=poster, src=src, duration=duration, current=current, progress=progress, playing=playing, attrs=attrs) }}{% endif %}
